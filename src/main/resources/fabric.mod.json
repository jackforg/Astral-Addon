{
  "schemaVersion": 1,
  "id": "astral",
  "version": "${version}",
  "name": "Astral Addon",
  "description": "Astral Addon by Forg is a curated module list for Astral Survival.",
  "authors": [
    "Forg"
  ],
  "contact": {
    "homepage": "https://github.com/jackforg/Astral-Addon",
    "issues": "https://github.com/jackforg/Astral-Addon/issues",
    "sources": "https://github.com/jackforg/Astral-Addon"
  },
  "icon": "assets/astral/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "dev.forg.forg"
    ]
  },
  "accessWidener": "forg.accesswidener",
  "mixins": [
    "forg.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "255,170,32"
  },
  "depends": {
    "java": ">=21",
    "minecraft": [
      "${mc_version}"
    ],
    "meteor-client": "*"
  }
}
